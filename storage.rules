rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /exercises/videos/{allPaths=**} {
      allow read: if request.auth != null;
      // Permite upload para Admins, Analistas e Professores
      allow write: if request.auth != null && (
        request.auth.uid == '1LGNVNiLzzXYEsJKh5JkXG21TA73' ||
        firestore.get(/databases/(default)/documents/userProfiles/$(request.auth.uid)).data.roleId in ['Administrator', 'Analyst', 'Professor']
      );
    }
  }
}
