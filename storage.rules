rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Regra Geral restritiva (Padrão Ethera)
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // --- REGRAS OLÍMPICA ---
    match /exercises/videos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == '1LGNVNiLzzXYEsJKh5JkXG21TA73' ||
        firestore.get(/databases/(default)/documents/userProfiles/$(request.auth.uid)).data.roleId in ['Administrator', 'Analyst', 'Professor']
      );
    }

    // --- REGRAS ETHERA ---
    match /attendance-photos/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /employee-docs/{employeeId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    match /uploads/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /receipts/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /profile-pictures/{userId} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
