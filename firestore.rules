rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funções Auxiliares
    function isAuthenticated() {
      return request.auth != null;
    }
    
    
    
    function isAdmin() {
      // Bypass temporário para troubleshooting do UID específico do usuário
      return isAuthenticated() && (request.auth.uid == '1LGNVNiLzzXYEsJKh5JkXG21TA73' || get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.roleId == 'Administrator');
    }
    
    function isAnalyst() {
      return isAuthenticated() && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.roleId == 'Analyst';
    }

    function isProfessor() {
      return isAuthenticated() && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.roleId == 'Professor';
    }

    // Regras para UserProfiles
    match /userProfiles/{userId} {
      // Regra fundamental: Você pode ler seu próprio perfil.
      // Admins e Analistas podem ler qualquer um.
      // Professor pode ler qualquer um (necessário para listar alunos).
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.roleId in ['Administrator', 'Analyst', 'Professor']
      );
      allow write: if isAuthenticated() && (
        request.auth.uid == userId || 
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.roleId == 'Administrator'
      );
      
      // Subcoleções do usuário (Sessões, Métricas, Anamnese)
      match /{allSubcollections=**} {
        allow read: if isAuthenticated() && (
          request.auth.uid == userId || 
          get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.roleId in ['Administrator', 'Analyst', 'Professor']
        );
        allow write: if isAuthenticated() && (
          request.auth.uid == userId || 
          get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.roleId in ['Administrator', 'Analyst']
        );
      }
    }

    // Regras para Roles (estático)
    match /roles/{roleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Regras para Exercícios
    match /exercises/{exerciseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isAnalyst() || isProfessor();
    }

    // Regras para Planos de Treino (TrainingPlans)
    match /trainingPlans/{planId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        isAnalyst() || 
        isProfessor() ||
        request.auth.uid == resource.data.createdByUserId ||
        request.auth.uid in resource.data.assignedToAthleteIds
      );
      allow create: if isAdmin() || isAnalyst() || isProfessor();
      allow update, delete: if isAdmin() || ((isAnalyst() || isProfessor()) && request.auth.uid == resource.data.createdByUserId);

      // Subcoleção de dias de treino
      match /workoutDays/{dayId} {
        // Usando get() para o pai ou desnormalização no futuro
        allow read: if isAuthenticated() && (
          isAdmin() || 
          isAnalyst() || 
          isProfessor() ||
          request.auth.uid == get(/databases/$(database)/documents/trainingPlans/$(planId)).data.createdByUserId ||
          request.auth.uid in get(/databases/$(database)/documents/trainingPlans/$(planId)).data.assignedToAthleteIds
        );
        allow write: if isAdmin() || isAnalyst() || isProfessor();
      }
    }
  }
}